        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--socket=[Path to the cmux socket (overrides discovery)]:SOCKET:_default' \
'--color=[Color mode\: always, never, auto]:COLOR:_default' \
'--json[Output raw JSON responses]' \
'-v[Verbose output (connection info to stderr)]' \
'--verbose[Verbose output (connection info to stderr)]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_cmux_commands" \
"*::: :->cmux" \
&& ret=0
