(( $+functions[_cmux_commands] )) ||
_cmux_commands() {
    local commands; commands=(
'ping:Ping the running cmux instance' \
'identify:Show cmux instance identity (version, platform, pid)' \
'capabilities:List supported socket commands' \
'list-workspaces:List all workspaces' \
'current-workspace:Show the current workspace' \
'raw:Send an arbitrary JSON-RPC method' \
'new-workspace:Create a new workspace' \
'select-workspace:Select a workspace by ID' \
'close-workspace:Close a workspace by ID' \
'rename-workspace:Rename a workspace' \
'next-workspace:Switch to next workspace' \
'prev-workspace:Switch to previous workspace' \
'last-workspace:Switch to last active workspace' \
'reorder-workspace:Reorder a workspace' \
'list-surfaces:List all surfaces' \
'split:Split a surface' \
'focus-surface:Focus a surface by ID' \
'close-surface:Close a surface by ID' \
'send-text:Send text to a surface' \
'send-key:Send a key event to a surface' \
'read-text:Read text from a surface' \
'health:Check surface health' \
'refresh:Refresh a surface' \
'list-panes:List all panes' \
'focus-pane:Focus a pane' \
'last-pane:Switch to last focused pane' \
'list-windows:List all windows' \
'current-window:Show current window info' \
'layout:Show layout tree' \
'type:Type text into the focused terminal' \
'list-notifications:List notifications' \
'clear-notification:Clear a notification' \
'browser-open:Open a URL in the browser pane' \
'browser-close:Close the browser pane' \
'browser-stream-enable:Enable browser streaming' \
'browser-stream-disable:Disable browser streaming' \
'browser-snapshot:Take a browser snapshot' \
'browser-screenshot:Take a browser screenshot' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cmux commands' commands "$@"
}
(( $+functions[_cmux__browser-close_commands] )) ||
_cmux__browser-close_commands() {
    local commands; commands=()
